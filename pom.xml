<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  
  <groupId>com.learney.contentaudit</groupId>
  <artifactId>contentaudit</artifactId>
  <version>0.0.1</version>
  <packaging>pom</packaging>
  
  <modules>
        <module>audit-domain</module>
        <module>course-domain</module>
        <module>refiner-domain</module>
        <module>audit-application</module>
        <module>course-infrastructure</module>
        <module>audit-cli</module>
        <module>nlp-infrastructure</module>
        <module>vocabulary-infrastructure</module>
        <module>audit-infrastructure</module>
        <module>revision-domain</module>

  </modules>

  <properties>
    <maven.compiler.source>17</maven.compiler.source>
    <maven.compiler.target>17</maven.compiler.target>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <junit.version>5.10.2</junit.version>
    <mockito.version>5.23.0</mockito.version>
  </properties>

  <dependencies>
    <dependency>
        <groupId>com.sentinel</groupId>
        <artifactId>sentinel-annotations</artifactId>
        <version>0.0.1-SNAPSHOT</version>
        <scope>test</scope>
    </dependency>
    <dependency>
        <groupId>org.junit.jupiter</groupId>
        <artifactId>junit-jupiter</artifactId>
        <version>${junit.version}</version>
        <scope>test</scope>
    </dependency>
    <dependency>
        <groupId>org.mockito</groupId>
        <artifactId>mockito-core</artifactId>
        <version>${mockito.version}</version>
        <scope>test</scope>
    </dependency>
    <dependency>
        <groupId>org.mockito</groupId>
        <artifactId>mockito-junit-jupiter</artifactId>
        <version>${mockito.version}</version>
        <scope>test</scope>
    </dependency>
    <dependency>
        <groupId>org.mockito</groupId>
        <artifactId>mockito-subclass</artifactId>
        <version>${mockito.version}</version>
        <scope>test</scope>
    </dependency>
    <dependency>
        <groupId>com.tngtech.archunit</groupId>
        <artifactId>archunit-junit5</artifactId>
        <version>1.2.1</version>
        <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>3.2.5</version>
        <configuration>
          <argLine>
            @{argLine} --add-opens java.base/java.lang=ALL-UNNAMED
            --add-opens java.base/java.lang.reflect=ALL-UNNAMED
            --add-opens java.base/java.lang.invoke=ALL-UNNAMED
            --add-opens java.base/java.util=ALL-UNNAMED
          </argLine>
          <useManifestOnlyJar>false</useManifestOnlyJar>
          <!-- Clear CONTENT_AUDIT_* env vars in test forks so tests don't inherit the
               developer's shell state (e.g., a user who exported CONTENT_AUDIT_CONTENT_FOLDER
               to exercise the CLI). Journey tests set these explicitly per ProcessBuilder. -->
          <environmentVariables>
            <CONTENT_AUDIT_CONTENT_FOLDER/>
            <CONTENT_AUDIT_HOME/>
            <CONTENT_AUDIT_WORKDIR/>
            <CONTENT_AUDIT_APPROVAL_MODE/>
          </environmentVariables>
        </configuration>
      </plugin>
      <plugin>
        <groupId>org.jacoco</groupId>
        <artifactId>jacoco-maven-plugin</artifactId>
        <version>0.8.12</version>
        <executions>
          <execution>
            <id>jacoco-prepare-agent</id>
            <goals><goal>prepare-agent</goal></goals>
            <configuration>
              <excludes>
                <exclude>sun/**</exclude>
                <exclude>jdk/**</exclude>
                <exclude>com/sun/**</exclude>
                <exclude>java/**</exclude>
              </excludes>
            </configuration>
          </execution>
          <execution>
            <id>jacoco-report</id>
            <phase>verify</phase>
            <goals><goal>report</goal></goals>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.pitest</groupId>
        <artifactId>pitest-maven</artifactId>
        <!-- Pin to 1.22.1: last version with built-in history (PIT 1.23+ moved history
             to the commercial arcmutate plugin). 1.22.1 also ships ASM 9.9 with Java 25
             (class major 69) support. -->
        <version>1.22.1</version>
        <dependencies>
          <dependency>
            <groupId>org.pitest</groupId>
            <artifactId>pitest-junit5-plugin</artifactId>
            <version>1.2.3</version>
          </dependency>
        </dependencies>
        <executions>
          <execution>
            <id>pit-mutation-coverage</id>
            <phase>verify</phase>
            <goals><goal>mutationCoverage</goal></goals>
          </execution>
        </executions>
        <configuration>
          <outputFormats>
            <format>HTML</format>
            <format>XML</format>
          </outputFormats>
          <mutators><mutator>DEFAULTS</mutator></mutators>
          <timeoutConstant>600000</timeoutConstant>
          <failWhenNoMutations>false</failWhenNoMutations>
          <historyInputFile>${maven.multiModuleProjectDirectory}/.sentinel/pit-history/${project.artifactId}.bin</historyInputFile>
          <historyOutputFile>${maven.multiModuleProjectDirectory}/.sentinel/pit-history/${project.artifactId}.bin</historyOutputFile>
          <!-- Disable surefire config inheritance: PIT's SurefireConfigConverter
               throws NPE when <environmentVariables> contains empty tags (used to clear
               CONTENT_AUDIT_* in test forks). We provide PIT's own config below. -->
          <parseSurefireConfig>false</parseSurefireConfig>
          <jvmArgs>
            <jvmArg>--add-opens=java.base/java.lang=ALL-UNNAMED</jvmArg>
            <jvmArg>--add-opens=java.base/java.lang.reflect=ALL-UNNAMED</jvmArg>
            <jvmArg>--add-opens=java.base/java.lang.invoke=ALL-UNNAMED</jvmArg>
            <jvmArg>--add-opens=java.base/java.util=ALL-UNNAMED</jvmArg>
          </jvmArgs>
          <!-- Mirror surefire's env var clearing so PIT test forks don't inherit
               developer shell state. PIT 1.22.1 NPEs on null env var values, so we
               must pass non-null strings. A single space works for vars whose reader
               uses isBlank() (CoursePathResolver, DefaultWorkdirResolver). For
               CONTENT_AUDIT_APPROVAL_MODE the reader uses isEmpty() and then matches
               against {auto, human}, so we set it to the default value "auto". -->
          <environmentVariables>
            <CONTENT_AUDIT_CONTENT_FOLDER xml:space="preserve"> </CONTENT_AUDIT_CONTENT_FOLDER>
            <CONTENT_AUDIT_HOME xml:space="preserve"> </CONTENT_AUDIT_HOME>
            <CONTENT_AUDIT_WORKDIR xml:space="preserve"> </CONTENT_AUDIT_WORKDIR>
            <CONTENT_AUDIT_APPROVAL_MODE>auto</CONTENT_AUDIT_APPROVAL_MODE>
          </environmentVariables>
        </configuration>
      </plugin>
      <plugin>
        <groupId>org.codehaus.mojo</groupId>
        <artifactId>exec-maven-plugin</artifactId>
        <version>3.1.0</version>
        <inherited>false</inherited>
        <executions>
          <execution>
            <id>sentinel-verify</id>
            <phase>validate</phase>
            <goals>
              <goal>exec</goal>
            </goals>
            <configuration>
              <executable>java</executable>
              <arguments>
                <argument>-jar</argument>
                <argument>/Users/josecullen/projects/sentinel/sentinel-core/target/sentinel-core-0.0.1-SNAPSHOT.jar</argument>
                <argument>verify</argument>
                <argument>-i</argument>
                <argument>sentinel.yaml</argument>
              </arguments>
            </configuration>
          </execution>
          <execution>
            <id>sentinel-report</id>
            <phase>verify</phase>
            <goals>
              <goal>exec</goal>
            </goals>
            <configuration>
              <executable>java</executable>
              <arguments>
                <argument>-jar</argument>
                <argument>/Users/josecullen/projects/sentinel/sentinel-core/target/sentinel-core-0.0.1-SNAPSHOT.jar</argument>
                <argument>report</argument>
                <argument>generate</argument>
                <argument>-i</argument>
                <argument>sentinel.yaml</argument>
              </arguments>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>

  <!-- Common dependencies can go here or in modules -->
</project>
